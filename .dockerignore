# Ignore environment files
.env*
!.env.example

# Ignore local development
docker-compose.local.yml

# Ignore build artifacts
dist/
node_modules/

# Ignore git
.git/
.gitignore

# Ignore documentation (optional - comment out if you want docs in production)
*.md
!README.md

# Ignore test files
test/
*.spec.ts
*.e2e-spec.ts
jest*.json

# Ignore CI/CD
.github/

# Ignore IDE
.vscode/
.idea/

# Ignore logs
*.log
npm-debug.log*
